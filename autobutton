    @loader.command(ru_doc="<номера слотов> - поставить слоты на паузу (например: 1, 123, 1-5, 1 3 5)")
    async def кстоп(self, message: Message) -> None:
        """Ставит слоты на паузу: .кстоп 1 или .кстоп 123 или .кстоп 1-5 или .кстоп 1 3 5-7"""
        args = utils.get_args_raw(message).strip()
        
        if not args:
            await utils.answer(message, self.strings("no_slot_number"))
            return
        
        slots = parse_slots(args, self._max_slots)
        
        if not slots:
            await utils.answer(message, self.strings("no_valid_slots"))
            return
        
        # Разделяем на уже на паузе и те, которые нужно поставить на паузу
        already_paused = []
        newly_paused = []
        
        for slot in slots:
            trigger, button, _, _, _, _, paused = self._get_rule(slot)
            if not trigger or not button:
                continue  # Пропускаем не настроенные
            if paused:
                already_paused.append(slot)
            else:
                self._set_rule(slot, paused=True)
                newly_paused.append(slot)
        
        # Формируем ответ
        messages = []
        if newly_paused:
            messages.append(self.strings("slot_paused").format(
                slots=", ".join(str(s) for s in newly_paused)
            ))
        if already_paused:
            messages.append(self.strings("slot_already_paused").format(
                slots=", ".join(str(s) for s in already_paused)
            ))
        
        if not messages:
            messages.append(self.strings("no_valid_slots"))
        
        await utils.answer(message, "\n".join(messages))

