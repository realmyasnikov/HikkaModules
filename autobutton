    @loader.command(ru_doc="- перезагрузить настройки из конфига")
    async def кконфиг(self, message: Message) -> None:
        """Перезагружает настройки слотов из конфига модуля"""
        self._load_config_slots()
        
        # Формируем отчёт о загруженных слотах
        loaded_slots = []
        for slot in range(1, self._max_slots + 1):
            config_trigger = self.config.get(f"slot{slot}_trigger", "").strip()
            config_button = self.config.get(f"slot{slot}_button", "").strip()
            
            if config_trigger and config_button:
                config_clicks = self.config.get(f"slot{slot}_clicks", 1)
                config_delay = self.config.get(f"slot{slot}_delay", 0.5)
                loaded_slots.append(
                    f"<b>Слот #{slot}:</b> ✅ {utils.escape_html(config_trigger)} → "
                    f"{utils.escape_html(config_button)} ({config_clicks} раз, {format_delay(config_delay)})"
                )
            else:
                loaded_slots.append(
                    f"<b>Слот #{slot}:</b> ❌ Не настроен"
                )
        
        if loaded_slots:
            result = "<b>✅ Конфигурация загружена:</b>\n\n" + "\n".join(loaded_slots)
        else:
            result = "<b>⚠️ В конфиге нет активных слотов.</b>"
        
        await utils.answer(message, result)