            clicks = 1
        else:
            button_text, _, clicks_str = args.partition("|")
            button_text = button_text.strip() or "*"
            clicks = 1
            if clicks_str.strip():
                try:
                    clicks = int(clicks_str.strip())
                    clicks = max(1, min(clicks, self.config["max_clicks"]))
                except ValueError:
                    clicks = 1

        clicked_count, label = await self._click_button(reply, button_text, clicks_count=clicks, delay_between=self.config["default_delay"])
        await utils.answer(
            message,
            self.strings("test_result").format(
                status="✅ успешно" if clicked_count > 0 else "❌ не нажал",
                clicked_count=clicked_count,
                total_clicks=clicks,
                button=utils.escape_html(label),
                buttons=utils.escape_html(self._state.get("last_buttons", "-")),
                debug=utils.escape_html(self._state.get("last_error", "-")),
            ),
        )

    @loader.command(ru_doc="- показать все кнопки в сообщении-реплае")
    async def кноп(self, message: Message) -> None:
        reply = await message.get_reply_message()
        if not reply:
            await utils.answer(message, self.strings("no_reply"))
            return

        try:
            await self._read_button_rows(reply)
            self._state["last_error"] = "ok"
            self._save_state()
        except Exception as e:
            self._state["last_buttons"] = "-"
            self._state["last_error"] = f"не смог прочитать кнопки: {type(e).__name__}"
            self._save_state()

        await utils.answer(
            message,
            self.strings("list_result").format(
                buttons=utils.escape_html(self._state.get("last_buttons", "-")),
            ),
        )

    @loader.command(ru_doc="- выключить все автокнопки")
    async def квыкл(self, message: Message) -> None:
        for slot in range(1, self._max_slots + 1):
            self._set_rule(slot, trigger=None, button=None, clicks=1, last_msg=0, paused=False)
        await utils.answer(message, self.strings("all_disabled"))

    @loader.command(ru_doc="<номер слота> - выключить конкретный слот")
    async def квыклн(self, message: Message) -> None:
        args = utils.get_args_raw(message).strip()
        if not args:
            await utils.answer(message, self.strings("no_slot_number"))
            return

        try:
            slot = int(args)
        except ValueError:
            await utils.answer(message, self.strings("invalid_slot_number"))
            return

        if slot < 1 or slot > self._max_slots:
            await utils.answer(message, self.strings("slot_out_of_range"))
            return

        self._set_rule(slot, trigger=None, button=None, clicks=1, last_msg=0, paused=False)
        await utils.answer(message, self.strings("slot_disabled").format(slot=slot))

    @loader.command(ru_doc="- показать статус всех автокнопок")
    async def кстат(self, message: Message) -> None:
        # Время последнего клика
        last_click = self._state.get("last_clicked_at", 0.0)
        if last_click:
            seconds_ago = int(self._now() - last_click)
            if seconds_ago < 60:
                last_click_str = f"✅ <code>{seconds_ago}с назад</code>"
            elif seconds_ago < 3600:
                last_click_str = f"✅ <code>{seconds_ago // 60}м назад</code>"
            else:
                last_click_str = f"✅ <code>{seconds_ago // 3600}ч назад</code>"
        else:
            last_click_str = "❌ <code>никогда</code>"

        active_count = self._count_active_rules()
        
        # Формируем статус
        result = self.strings("status_header").format(active=active_count, total=self._max_slots)

        # Показываем информацию о каждом слоте
        for slot in range(1, self._max_slots + 1):
            trigger, button, clicks, delay, _, chat, paused = self._get_rule(slot)

            # Определяем статус слота
            if trigger and button:
                if paused:
                    slot_status = self.strings("slot_paused_status")
                else:
                    slot_status = self.strings("slot_active")
                
                trigger_str = f"✅ <code>{utils.escape_html(trigger)}</code>"
                button_str = f"✅ <code>{utils.escape_html(button)}</code>"
                clicks_str = f"✅ <code>{clicks}</code>"
                delay_str = f"✅ <code>{format_delay(delay)}</code>"
                
                # Показываем источник настройки
                config_trigger = self.config.get(f"slot{slot}_trigger", "").strip()
                if config_trigger == trigger:
                    source = " 📋конфиг"
                else:
                    source = " 💬команда"
            else:
                slot_status = self.strings("slot_not_configured_status")
                trigger_str = "❌ <code>-</code>"
                button_str = "❌ <code>-</code>"
                clicks_str = "❌ <code>-</code>"
                delay_str = "❌ <code>-</code>"
                source = ""

            chat_str = f"✅ <code>{chat}</code>" if chat else "❌ <code>везде</code>"

            result += self.strings("status_slot").format(
                slot=slot,
                status=slot_status,
                trigger=trigger_str + source,
                button=button_str,
                clicks=clicks_str,
                delay=delay_str,
                chat=chat_str,
            )

        log_chat_id = self._state.get("log_chat_id")
        if log_chat_id:
            log_status = f"✅ <code>{log_chat_id}</code>"
        else:
            log_status = "❌ <code>только консоль</code>"

        result += self.strings("status_footer").format(
            log_status=log_status,
            last_click=last_click_str,
            last_buttons=utils.escape_html(self._state.get("last_buttons", "-")),
            last_error=utils.escape_html(self._state.get("last_error", "-")),
        )

        await utils.answer(message, result)

