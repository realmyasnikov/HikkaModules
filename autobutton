    def _default_state(self) -> Dict[str, Any]:
        state: Dict[str, Any] = {
            "last_clicked_at": 0.0,
            "last_buttons": "-",
            "last_error": "-",
            "log_chat_id": None,
        }
        for slot in range(1, self._max_slots + 1):
            state[f"button{slot}_trigger"] = None
            state[f"button{slot}_target"] = None
            state[f"button{slot}_clicks"] = 1
            state[f"button{slot}_delay"] = self.config["default_delay"]
            state[f"button{slot}_last_msg"] = 0
            state[f"button{slot}_chat"] = None
            state[f"button{slot}_paused"] = False
        return state

    async def client_ready(self, client: Any, db: Any) -> None:
        self._client = client
        self._db = db
        saved_state = self.get("state", {}) or {}
        default_state = self._default_state()
        for key, value in default_state.items():
            if key not in saved_state:
                saved_state[key] = value
        self._state = {**default_state, **saved_state}
        
        # Загружаем настройки из конфига
        self._load_config_slots()
        self._save_state()

    def _load_config_slots(self) -> None:
        """Загружает настройки слотов из конфига модуля"""
        for slot in range(1, self._max_slots + 1):
            trigger_key = f"slot{slot}_trigger"
            button_key = f"slot{slot}_button"
            clicks_key = f"slot{slot}_clicks"
            delay_key = f"slot{slot}_delay"
            
            config_trigger = self.config.get(trigger_key, "").strip()
            config_button = self.config.get(button_key, "").strip()
            config_clicks = self.config.get(clicks_key, 1)
            config_delay = self.config.get(delay_key, 0.5)
            
            if config_trigger and config_button:
                self._set_rule(
                    slot,
                    trigger=config_trigger,
                    button=config_button,
                    clicks=config_clicks,
                    delay=config_delay,
                    last_msg=0,
                )
                logger.info(f"Слот #{slot} загружен из конфига: {config_trigger} -> {config_button}")

    def _save_state(self) -> None:
        if self._db:
            self.set("state", self._state)

    @staticmethod
    def _now() -> float:
        import time
        return time.time()

    @staticmethod
    def _text(message: Message) -> str:
        return getattr(message, "raw_text", None) or getattr(message, "message", "") or ""

    def _contains_any(self, text: str, markers: Tuple[str, ...]) -> bool:
        if not text:
            return False
        normalized = _normalize(text)
        compact = _compact(text)
        folded = _fold_text(text)
        for marker in markers:
            if not marker:
                continue
            marker_normalized = _normalize(marker)
            marker_compact = _compact(marker)
            marker_folded = _fold_text(marker)
            if marker_normalized and marker_normalized in normalized:
                return True
            if marker_compact and marker_compact in compact:
                return True
            if marker_folded and marker_folded in folded:
                return True
        return False

    @staticmethod
    def _button_rows(buttons: Any) -> List[List[Any]]:
        rows: List[List[Any]] = []
        if not buttons:
            return rows
        for row in buttons:
            row_buttons = getattr(row, "buttons", None)
            if row_buttons is not None:
                rows.append(list(row_buttons))
            elif isinstance(row, (list, tuple)):
                rows.append(list(row))
            else:
                rows.append([row])
        return rows

    @staticmethod
    def _button_label(button: Any) -> str:
        return str(getattr(button, "text", "") or button).strip()

    def _button_matches(self, expected: str, label: str) -> bool:
        expected = (expected or "").strip()
        if not expected:
            return False
        if expected in {"*", "первая", "first", "1"}:
            return True
        expected_normalized = _normalize(expected)
        label_normalized = _normalize(label or "")
        if expected_normalized and expected_normalized in label_normalized:
            return True
        expected_folded = _fold_text(expected)
        label_folded = _fold_text(label or "")
        return bool(expected_folded and expected_folded in label_folded)

    def _field_names(self, slot: int) -> Tuple[str, str, str, str, str, str, str]:
        return (
            f"button{slot}_trigger",
            f"button{slot}_target",
            f"button{slot}_clicks",
            f"button{slot}_delay",
            f"button{slot}_last_msg",
            f"button{slot}_chat",
            f"button{slot}_paused",
        )

    def _get_rule(self, slot: int) -> Tuple[Optional[str], Optional[str], int, float, int, Optional[int], bool]:
        trigger_key, target_key, clicks_key, delay_key, last_key, chat_key, paused_key = self._field_names(slot)
        return (
            self._state.get(trigger_key),
            self._state.get(target_key),
            int(self._state.get(clicks_key) or 1),
            float(self._state.get(delay_key) or self.config["default_delay"]),
            int(self._state.get(last_key) or 0),
            self._state.get(chat_key),
            bool(self._state.get(paused_key, False)),
        )

    def _set_rule(
        self,
        slot: int,
        *,
        trigger: Optional[str] = None,
        button: Optional[str] = None,
        clicks: Optional[int] = None,
        delay: Optional[float] = None,
        last_msg: Optional[int] = None,
        chat_id: Optional[int] = None,
        paused: Optional[bool] = None,
    ) -> None:
        trigger_key, target_key, clicks_key, delay_key, last_key, chat_key, paused_key = self._field_names(slot)
        if trigger is not None:
            self._state[trigger_key] = trigger
        if button is not None:
            self._state[target_key] = button
        if clicks is not None:
            self._state[clicks_key] = max(1, min(clicks, self.config["max_clicks"]))
        if delay is not None:
            self._state[delay_key] = max(0.1, min(delay, 600.0))
        if last_msg is not None:
            self._state[last_key] = int(last_msg)
        if chat_id is not None:
            self._state[chat_key] = int(chat_id) if chat_id else None
        if paused is not None:
            self._state[paused_key] = bool(paused)
        self._save_state()

    def _has_any_rule(self) -> bool:
        for slot in range(1, self._max_slots + 1):
            trigger, button, _, _, _, _, paused = self._get_rule(slot)
            if trigger and button and not paused:
                return True
        return False

    def _count_active_rules(self) -> int:
        count = 0
        for slot in range(1, self._max_slots + 1):
            trigger, button, _, _, _, _, paused = self._get_rule(slot)
            if trigger and button and not paused:
                count += 1
        return count

    async def _send_log(self, text: str) -> None:
        log_chat_id = self._state.get("log_chat_id")
        if log_chat_id and self._client:
            try:
                await self._client.send_message(log_chat_id, text)
            except Exception as e:
                logger.error("Failed to send log to chat %s: %s", log_chat_id, e)
                if self.config["log_to_console"]:
                    logger.info(text)
        elif self.config["log_to_console"]:
            logger.info(text)

    async def _get_message_link(self, message: Message) -> str:
        try:
            chat_id = message.chat_id
            message_id = message.id
            if chat_id and self._client:
                try:
                    entity = await self._client.get_entity(chat_id)
                    username = getattr(entity, "username", None)
                    if username:
                        return f"https://t.me/{username}/{message_id}"
                except Exception:
                    pass
                chat_id_str = str(chat_id)
                if chat_id_str.startswith("-100"):
                    return f"https://t.me/c/{chat_id_str[4:]}/{message_id}"
                else:
                    return f"https://t.me/c/{chat_id_str}/{message_id}"
        except Exception:
            pass
        return f"ID сообщения: {getattr(message, 'id', 0)}"

    async def _read_button_rows(self, message: Message) -> List[List[Any]]:
        buttons = getattr(message, "buttons", None)
        if not buttons:
            try:
                buttons = await message.get_buttons()
            except Exception as e:
                logger.debug("get_buttons failed: %s", e)
                buttons = None
        rows = self._button_rows(buttons)
        labels = [self._button_label(button) for row in rows for button in row]
        self._state["last_buttons"] = ", ".join(labels) if labels else "-"
        self._save_state()
        return rows

    async def _click_button(
        self,
        message: Message,
        button_text: str,
        *,
        slot: Optional[int] = None,
        clicks_count: int = 1,
        delay_between: float = 0.5,
    ) -> Tuple[int, str]:
        try:
            rows = await self._read_button_rows(message)
        except Exception as e:
            self._state["last_error"] = f"не смог прочитать кнопки: {type(e).__name__}"
            self._save_state()
            logger.exception("Failed to fetch buttons for message %s", getattr(message, "id", 0))
            return 0, "-"

        if not rows:
            self._state["last_error"] = "в сообщении нет кнопок"
            self._save_state()
            return 0, "-"

        target_coords = None
        target_label = None

        for row_index, row in enumerate(rows):
            for button_index, button in enumerate(row):
                label = self._button_label(button)
                if self._button_matches(button_text, label):
                    target_coords = (row_index, button_index)
                    target_label = label
                    break
            if target_coords:
                break

        if not target_coords:
            flat_buttons = [
                (row_index, button_index, button)
                for row_index, row in enumerate(rows)
                for button_index, button in enumerate(row)
            ]
            if len(flat_buttons) == 1:
                row_index, button_index, button = flat_buttons[0]
                target_coords = (row_index, button_index)
                target_label = self._button_label(button)

        if not target_coords:
            self._state["last_error"] = "подходящая кнопка не найдена"
            self._save_state()
            return 0, "-"

        success_count = 0

        for i in range(clicks_count):
            try:
                row_idx, btn_idx = target_coords
                await message.click(row_idx, btn_idx)
                success_count += 1

                if slot is not None:
                    self._set_rule(slot, last_msg=getattr(message, "id", 0) or 0)

                self._state["last_clicked_at"] = self._now()
                self._state["last_error"] = f"ok: {target_label} ({i+1}/{clicks_count})"
                self._save_state()

                if i < clicks_count - 1 and delay_between > 0:
                    await asyncio.sleep(delay_between)

            except Exception as e:
                self._state["last_error"] = f"ошибка клика {i+1}: {type(e).__name__}: {e}"
                self._save_state()
                logger.exception(
                    "Failed to click button %r (attempt %d/%d) for message %s",
                    target_label,
                    i + 1,
                    clicks_count,
                    getattr(message, "id", 0),
                )
                break

        return success_count, target_label or "-"

    async def _maybe_click_by_rule(self, message: Message, slot: int) -> bool:
        try:
            trigger, button, clicks, delay, last_msg, chat_id, paused = self._get_rule(slot)
            if not trigger or not button or paused:
                return False

            message_chat = getattr(message, "chat_id", None)
            if chat_id is not None and message_chat != chat_id:
                return False

            message_id = int(getattr(message, "id", 0) or 0)
            if message_id and message_id == last_msg:
                return False

            text = self._text(message)
            if not text or not self._contains_any(text, (trigger,)):
                return False

            clicked_count, label = await self._click_button(
                message, button, slot=slot, clicks_count=clicks, delay_between=delay
            )

            if clicked_count > 0:
                message_link = await self._get_message_link(message)
                chat_id_str = str(message_chat) if message_chat else "unknown"

                logger.info(
                    "Clicked button slot %s (%r -> %r) %d/%d times on message %s in chat %s (delay=%s)",
                    slot, trigger, label, clicked_count, clicks, message_id, chat_id_str, delay
                )

                if clicked_count == clicks:
                    log_text = self.strings("clicked_all_log").format(
                        slot=slot,
                        total_clicks=clicks,
                        trigger=utils.escape_html(str(trigger)),
                        button=utils.escape_html(label),
                        chat_id=chat_id_str,
                        message_link=message_link,
                    )
                else:
                    log_text = self.strings("clicked_log").format(
                        slot=slot,
                        click_num=clicked_count,
                        total_clicks=clicks,
                        trigger=utils.escape_html(str(trigger)),
                        button=utils.escape_html(label),
                        chat_id=chat_id_str,
                        message_link=message_link,
                    )

                await self._send_log(log_text)

            return clicked_count > 0
        except Exception as e:
            logger.exception("Error in _maybe_click_by_rule for slot %s: %s", slot, e)
            return False

    @loader.watcher("in")
    async def button_watcher(self, message: Message) -> None:
        if not self._client or not self._has_any_rule():
            return

        try:
            for slot in range(1, self._max_slots + 1):
                if await self._maybe_click_by_rule(message, slot):
                    return
        except Exception as e:
            logger.exception("Error in button_watcher: %s", e)

    def _parse_args_with_clicks(self, args: str) -> Tuple[str, str, int]:
        parts = [p.strip() for p in args.split("|")]

        if len(parts) == 1:
            return parts[0], "", 1

        trigger = parts[0]
        button = parts[1] if len(parts) > 1 else ""
        clicks = 1

        if len(parts) >= 3 and parts[2]:
            try:
                clicks = int(parts[2])
                clicks = max(1, min(clicks, self.config["max_clicks"]))
            except ValueError:
                clicks = 1

        return trigger, button, clicks

    async def _configure_slot(self, message: Message, slot: int, args: str) -> None:
        if slot < 1 or slot > self._max_slots:
            await utils.answer(message, self.strings("slot_out_of_range"))
            return

        if not args:
            await utils.answer(message, self.strings("no_args"))
            return

        if args.lower() in {"выкл", "стоп", "0"}:
            self._set_rule(slot, trigger=None, button=None, clicks=1, last_msg=0, paused=False)
            await utils.answer(message, self.strings("disabled").format(slot=slot))
            return

        trigger, button, clicks = self._parse_args_with_clicks(args)

        if not trigger or not button:
            await utils.answer(message, self.strings("usage"))
            return

        _, _, _, current_delay, _, _, _ = self._get_rule(slot)

        self._set_rule(slot, trigger=trigger, button=button, clicks=clicks, delay=current_delay, last_msg=0, paused=False)

        await utils.answer(
            message,
            self.strings("enabled").format(
                slot=slot,
                trigger=utils.escape_html(trigger),
                button=utils.escape_html(button),
                clicks=clicks,
                delay=format_delay(current_delay),
            ),
        )

    async def _set_slot_delay(self, message: Message) -> None:
        args = utils.get_args_raw(message).strip()

        if not args:
            await utils.answer(message, self.strings("delay_usage"))
            return

        parts = args.split(maxsplit=1)
        if len(parts) != 2:
            await utils.answer(message, self.strings("delay_usage"))
            return

        try:
            slot = int(parts[0])
        except ValueError:
            await utils.answer(message, self.strings("invalid_slot_number"))
            return

        if slot < 1 or slot > self._max_slots:
            await utils.answer(message, self.strings("slot_out_of_range"))
            return

        delay_str = parts[1]
        delay_seconds = parse_delay(delay_str)

        self._set_rule(slot, delay=delay_seconds)

        trigger, button, clicks, _, _, _, _ = self._get_rule(slot)
        delay_formatted = format_delay(delay_seconds)

        if trigger and button:
            await utils.answer(
                message,
                f"<b>✅ Задержка для слота #{slot} установлена:</b> <code>{delay_formatted}</code>\n"
                f"🎯 Триггер: <code>{utils.escape_html(trigger)}</code>\n"
                f"🔘 Кнопка: <code>{utils.escape_html(button)}</code>"
            )
        else:
            await utils.answer(
                message,
                self.strings("delay_set").format(slot=slot, delay=delay_formatted)
            )

    async def _resolve_chat_id(self, input_str: str) -> Optional[int]:
        if not input_str:
            return None

        if input_str.lstrip("-").isdigit():
            return int(input_str)

        try:
            entity = await self._client.get_entity(input_str)
            return int(utils.get_entity_id(entity))
        except (UsernameNotOccupiedError, ValueError, ChatAdminRequiredError, ChannelPrivateError):
            return None
        except Exception:
            return None

    async def _configure_chat(self, message: Message, slot: int, args: str) -> None:
        if slot < 1 or slot > self._max_slots:
            await utils.answer(message, self.strings("slot_out_of_range"))
            return

        if args.lower() in {"выкл", "сброс", "0"}:
            self._set_rule(slot, chat_id=None)
            await utils.answer(message, self.strings("chat_reset").format(slot=slot))
            return

        if not args:
            chat_id = getattr(message, "chat_id", None)
            if not chat_id:
                await utils.answer(message, self.strings("bad_entity"))
                return

            self._set_rule(slot, chat_id=chat_id)
            await utils.answer(
                message,
                self.strings("chat_set_current").format(slot=slot, chat_id=chat_id),
            )
            return

        chat_id = await self._resolve_chat_id(args)

        if not chat_id:
            await utils.answer(message, self.strings("bad_entity"))
            return

        self._set_rule(slot, chat_id=chat_id)
        await utils.answer(
            message,
            self.strings("chat_set").format(slot=slot, chat_id=chat_id),
        )

    async def _configure_log_chat(self, message: Message, args: str) -> None:
        if args.lower() in {"выкл", "сброс", "0"}:
            self._state["log_chat_id"] = None
            self._save_state()
            await utils.answer(message, self.strings("log_chat_reset"))
