def _normalize(text: str) -> str:
    return " ".join((text or "").lower().split())


def _compact(text: str) -> str:
    return "".join((text or "").lower().split())


def _fold_text(text: str) -> str:
    normalized = unicodedata.normalize("NFKC", text or "").lower().replace("ё", "е")
    chars = []
    for char in normalized:
        category = unicodedata.category(char)
        if category in {"Mn", "Cf"}:
            continue
        if char.isalnum():
            chars.append(char)
    return "".join(chars)


def parse_delay(delay_str: str) -> float:
    """Парсит задержку из формата '1м 1с', '5с', '2м', '0.5м' и т.д."""
    if not delay_str:
        return 0.5

    delay_str = delay_str.strip().lower()
    total_seconds = 0.0

    patterns = [
        (r'(\d+(?:\.\d+)?)\s*ч', 3600),
        (r'(\d+(?:\.\d+)?)\s*час', 3600),
        (r'(\d+(?:\.\d+)?)\s*м', 60),
        (r'(\d+(?:\.\d+)?)\s*мин', 60),
        (r'(\d+(?:\.\d+)?)\s*с', 1),
        (r'(\d+(?:\.\d+)?)\s*сек', 1),
    ]

    for pattern, multiplier in patterns:
        matches = re.findall(pattern, delay_str)
        for match in matches:
            total_seconds += float(match) * multiplier

    if total_seconds == 0:
        try:
            total_seconds = float(delay_str)
        except ValueError:
            total_seconds = 0.5

    return max(0.1, min(total_seconds, 600.0))


def format_delay(seconds: float) -> str:
    """Форматирует задержку в читаемый вид"""
    seconds = round(seconds, 1)
    if seconds >= 60:
        minutes = int(seconds // 60)
        secs = seconds % 60
        if secs >= 0.9:
            return f"{minutes}м {secs:.0f}с"
        return f"{minutes}м"
    elif seconds >= 1:
        return f"{seconds:.0f}с"
    else:
        return f"{seconds:.1f}с"


def parse_slots(slots_str: str, max_slots: int = 10) -> List[int]:
    """
    Парсит строку со слотами в список номеров.
    Поддерживает форматы:
    - "1" - один слот
    - "123" - несколько слотов подряд
    - "1 2 3" - слоты через пробел
    - "1,2,3" - слоты через запятую
    - "1-3" - диапазон слотов
    - "1-3 5 7-9" - смешанный формат
    """
    if not slots_str:
        return []
    
    # Заменяем запятые на пробелы
    slots_str = slots_str.replace(",", " ")
    
    # Ищем диапазоны (например, "1-3")
    parts = []
    for part in slots_str.split():
        if "-" in part:
            try:
                start, end = part.split("-", 1)
                start_num = int(start)
                end_num = int(end)
                if start_num <= end_num:
                    parts.extend(range(start_num, end_num + 1))
                else:
                    parts.extend(range(end_num, start_num + 1))
            except ValueError:
                continue
        else:
            # Проверяем, не является ли это строкой из нескольких цифр подряд (например, "123")
            if part.isdigit() and len(part) > 1:
                # Разбиваем на отдельные цифры
                parts.extend([int(d) for d in part])
            else:
                try:
                    parts.append(int(part))
                except ValueError:
                    continue
    
    # Фильтруем и сортируем
    valid_slots = sorted(set([s for s in parts if 1 <= s <= max_slots]))
    return valid_slots


